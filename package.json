{
  "name": "@agentage/find-mcp",
  "version": "0.1.0",
  "mcpName": "io.agentage/find-mcp",
  "description": "Find MCP - the npm client for the agentage MCP directory: thin stdio MCP proxy bridging stdio-only clients (Claude Desktop, Cursor, VS Code) to catalog.agentage.io/mcp - search 12,000+ MCP servers from any MCP client.",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "find-mcp",
    "mcp-catalog",
    "mcp-registry",
    "claude",
    "cursor",
    "agentage"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentage/find-mcp.git"
  },
  "homepage": "https://catalog.agentage.io/mcp",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "agentage-find-mcp": "dist/bin/find-mcp.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "format": "prettier --write \"{src,test}/**/*.ts\"",
    "format:check": "prettier --check \"{src,test}/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist *.tsbuildinfo coverage",
    "verify": "npm run type-check && npm run lint && npm run format:check && npm run test && npm run build",
    "prepublishOnly": "npm run verify"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.4.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
